PORT=
CLIENT_HOST=
DATABASE_URL=
# Public origin Better Auth serves from — drives cookie domain and redirects.
# Per-environment (dev/staging/prod); never hardcode in source.
BETTER_AUTH_URL=
# Comma-separated extra origins Better Auth accepts besides its baseURL
# (e.g. http://localhost:4173 so Playwright e2e can run against `vite preview`)
TRUSTED_ORIGINS=

# Auth rate limiting (Postgres-backed, per IP+path). Defaults to on only when
# NODE_ENV=production; set true/false to override (e2e enables it on a
# dedicated API instance — see apps/web/playwright.config.ts).
RATE_LIMIT_ENABLED=

# ── Email (EmailProvider, architecture §10) ───────────────────────────────────
# With MAILGUN_API_KEY unset, dev falls back to a file outbox (no real sends):
# messages land as JSON in EMAIL_OUTBOX_DIR (default .email-outbox).
# Production refuses to boot without a real provider.
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
# Only for the EU region (https://api.eu.mailgun.net); default is the US API.
MAILGUN_BASE_URL=
# RFC 5322 sender, e.g. auth-starter <no-reply@mail.example.com>
EMAIL_FROM=
EMAIL_OUTBOX_DIR=

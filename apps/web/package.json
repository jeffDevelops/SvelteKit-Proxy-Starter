{
  "name": "web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "start:dev": "vite dev",
    "dev": "pm2 start bun --name \"sveltekit\" -- run start:dev",
    "start:build": "bun build/index.js",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test:unit": "vitest run",
    "test": "bun run test:unit && bun run test:e2e",
    "test:e2e": "playwright test",
    "playwright:install": "playwright install chromium"
  },
  "dependencies": {
    "@better-auth/passkey": "^1.6.23",
    "@auth-starter/types": "0.0.1",
    "@auth-starter/validation": "0.0.1",
    "@sveltejs/adapter-node": "^5.5.4",
    "better-auth": "^1.6.23",
    "hono": "^4.12.27",
    "pm2": "^7.0.1",
    "uqr": "^0.1.3"
  },
  "devDependencies": {
    "@internationalized/date": "^3.12.0",
    "@lucide/svelte": "^1.22.0",
    "@playwright/test": "^1.60.0",
    "@auth-starter/api": "workspace:*",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "^2.63.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.1",
    "@vitest/browser-playwright": "^4.1.8",
    "bits-ui": "^2.16.3",
    "clsx": "^2.1.1",
    "playwright": "^1.60.0",
    "shadcn-svelte": "^1.3.0",
    "svelte": "^5.56.1",
    "svelte-check": "^4.6.0",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "vitest-browser-svelte": "^2.1.1"
  }
}

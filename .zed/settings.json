{
  "format_on_save": "on",
  "formatter": {
    "external": {
      "command": "./node_modules/.bin/oxfmt",
      "arguments": ["--stdin-filepath", "{buffer_path}"]
    }
  },
  "languages": {
    "TypeScript": {
      "formatter": {
        "external": {
          "command": "./node_modules/.bin/oxfmt",
          "arguments": ["--stdin-filepath", "{buffer_path}"]
        }
      }
    },
    "Svelte": {
      "formatter": {
        "external": {
          "command": "./node_modules/.bin/prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"]
        }
      }
    }
  }
}

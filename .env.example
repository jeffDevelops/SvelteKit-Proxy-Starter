# Copy to .env and fill in values. Never commit .env.

# ── PostgreSQL (dev: Docker on VPS; staging/prod: Render managed Postgres) ────
POSTGRES_USER=auth-starter
POSTGRES_PASSWORD=changeme

# Full connection string consumed by apps/api and packages/db.
# Must match the POSTGRES_* vars above for the dev Docker instance.
DATABASE_URL=postgres://auth-starter:changeme@localhost:5432/auth-starter_dev

CLIENT_HOST=
